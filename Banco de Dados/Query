IF EXISTS (SELECT * FROM sys.databases WHERE name = 'FoodVerseDB')
BEGIN
    DROP DATABASE FoodVerseDB;
END
GO

CREATE DATABASE FoodVerseDB;
GO

USE FoodVerseDB;
GO


-- CLIENTES
CREATE TABLE tb_clientes (
    ID_cliente INT IDENTITY PRIMARY KEY,
    username VARCHAR(50) UNIQUE,
    nome VARCHAR(100),
    email VARCHAR(100) UNIQUE,
    telefone VARCHAR(20),
    cpf VARCHAR(14) UNIQUE,
    senha VARCHAR(255),
    endereco VARCHAR(255),
    data_cadastro DATETIME DEFAULT GETDATE()
);


-- RESTAURANTES
CREATE TABLE tb_restaurantes (
    ID_restaurante INT IDENTITY PRIMARY KEY,
    nome VARCHAR(100),
    categoria VARCHAR(50),
    descricao VARCHAR(255),
    avaliacao DECIMAL(3,2),
    tempo_entrega VARCHAR(20),
    taxa_entrega DECIMAL(10,2),
    cupom VARCHAR(50),
    imagem VARCHAR(255)
);


-- PRODUTOS (PRATOS)
CREATE TABLE tb_produtos (
    ID_produto INT IDENTITY PRIMARY KEY,
    ID_restaurante INT,
    nome_produto VARCHAR(100),
    descricao VARCHAR(255),
    preco DECIMAL(10,2),
    categoria VARCHAR(50),
    imagem VARCHAR(255),
    tempo_preparo INT,
    disponivel BIT DEFAULT 1,
    destaque BIT DEFAULT 0,
    data_criacao DATETIME DEFAULT GETDATE(),
    FOREIGN KEY (ID_restaurante)
    REFERENCES tb_restaurantes(ID_restaurante)
);

-- Estoque

CREATE TABLE tb_estoque (
    ID_estoque INT IDENTITY PRIMARY KEY,
    ID_produto INT,
    quantidade INT,
    estoque_minimo INT,
    ultima_atualizacao DATETIME DEFAULT GETDATE(),

    FOREIGN KEY (ID_produto)
    REFERENCES tb_produtos(ID_produto)
);

-- NUTRIÇÃO DOS PRATOS
CREATE TABLE tb_nutricao (
    ID_nutricao INT IDENTITY PRIMARY KEY,
    ID_produto INT,
    kcal INT,
    proteina VARCHAR(20),
    carbo VARCHAR(20),
    gordura VARCHAR(20),

    FOREIGN KEY (ID_produto)
    REFERENCES tb_produtos(ID_produto)
);


-- STATUS DO PEDIDO
CREATE TABLE tb_status_pedido (
    ID_status INT PRIMARY KEY,
    nome_status VARCHAR(50)
);


-- PEDIDOS
CREATE TABLE tb_pedidos (
    ID_pedido INT IDENTITY PRIMARY KEY,
    ID_cliente INT,
    ID_restaurante INT,
    data_pedido DATETIME DEFAULT GETDATE(),
    endereco_entrega VARCHAR(255),
    status_id INT,
    valor_total DECIMAL(10,2),

    FOREIGN KEY (ID_cliente)
    REFERENCES tb_clientes(ID_cliente),

    FOREIGN KEY (ID_restaurante)
    REFERENCES tb_restaurantes(ID_restaurante),

    FOREIGN KEY (status_id)
    REFERENCES tb_status_pedido(ID_status)
);


-- PRODUTOS DO PEDIDO
CREATE TABLE tb_pedidos_produtos (
    ID_pedido INT,
    ID_produto INT,
    quantidade INT,

    PRIMARY KEY (ID_pedido, ID_produto),

    FOREIGN KEY (ID_pedido)
    REFERENCES tb_pedidos(ID_pedido),

    FOREIGN KEY (ID_produto)
    REFERENCES tb_produtos(ID_produto)
);


-- RESERVAS
CREATE TABLE tb_reservas (
    ID_reserva INT IDENTITY PRIMARY KEY,
    ID_cliente INT,
    ID_restaurante INT,
    data_reserva DATETIME,
    numero_pessoas INT,
    mesa VARCHAR(10),

    FOREIGN KEY (ID_cliente)
    REFERENCES tb_clientes(ID_cliente),

    FOREIGN KEY (ID_restaurante)
    REFERENCES tb_restaurantes(ID_restaurante)
);


-- PAGAMENTOS
CREATE TABLE tb_pagamentos (
    ID_pagamento INT IDENTITY PRIMARY KEY,
    ID_pedido INT,
    metodo_pagamento VARCHAR(50),
    valor DECIMAL(10,2),
    data_pagamento DATETIME DEFAULT GETDATE(),

    FOREIGN KEY (ID_pedido)
    REFERENCES tb_pedidos(ID_pedido)
);


-- AVALIAÇÕES
CREATE TABLE tb_avaliacoes (
    ID_avaliacao INT IDENTITY PRIMARY KEY,
    ID_cliente INT,
    ID_restaurante INT,
    comentario VARCHAR(255),
    nota INT,
    data_avaliacao DATETIME DEFAULT GETDATE(),

    FOREIGN KEY (ID_cliente)
    REFERENCES tb_clientes(ID_cliente),

    FOREIGN KEY (ID_restaurante)
    REFERENCES tb_restaurantes(ID_restaurante)
);


-- CUPONS
CREATE TABLE tb_cupons (
    ID_cupom INT IDENTITY PRIMARY KEY,
    codigo VARCHAR(50),
    desconto DECIMAL(5,2),
    validade DATE
);


-- FIDELIDADE
CREATE TABLE tb_fidelidade (
    ID_fidelidade INT IDENTITY PRIMARY KEY,
    ID_cliente INT,
    pontos INT,
    cashback DECIMAL(10,2),

    FOREIGN KEY (ID_cliente)
    REFERENCES tb_clientes(ID_cliente)
);


-- FUNCIONÁRIOS
CREATE TABLE tb_funcionarios (
    ID_funcionario INT IDENTITY PRIMARY KEY,
    ID_restaurante INT,
    nome VARCHAR(100),
    username VARCHAR(50),
    email VARCHAR(100),
    cargo VARCHAR(50),
    telefone VARCHAR(20),
    senha VARCHAR(255),
    status VARCHAR(20),
    data_cadastro DATETIME DEFAULT GETDATE(),

    FOREIGN KEY (ID_restaurante)
    REFERENCES tb_restaurantes(ID_restaurante)
    ON DELETE SET NULL
);