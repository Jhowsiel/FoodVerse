create database FoodVerseDB

use FoodVerseDB


CREATE TABLE tb_funcionarios (
    id INT identity PRIMARY KEY,
    name VARCHAR(100),
    userName VARCHAR(50),
    email VARCHAR(100) ,
    role VARCHAR(50) ,
    phone VARCHAR(20) ,
    password VARCHAR(255),
    registrationDate varchar(20),
    status varchar(20)
);

