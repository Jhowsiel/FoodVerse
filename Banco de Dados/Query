iF EXISTS (SELECT * FROM sys.databases WHERE name = 'FoodVerseDB')
BEGIN
    DROP DATABASE FoodVerseDB;
END
GO

CREATE DATABASE FoodVerseDB;
GO

USE FoodVerseDB;
GO

CREATE TABLE tb_clientes (
    UserId INT IDENTITY PRIMARY KEY,
    user_name VARCHAR(100),
    name VARCHAR(100),
    email VARCHAR(100),
    phone VARCHAR(100),
    password VARCHAR(255),
    cpf VARCHAR(255),
    registrationDate DATE,
    isLogin BIT
);
GO

CREATE TABLE tb_produtos (
    ID_produto INT IDENTITY PRIMARY KEY,
    nome_produto VARCHAR(100),
    des_produto VARCHAR(255),
    preco_produto DECIMAL(10,2)
);
GO

CREATE TABLE tb_reservas (
    ID_reserva INT IDENTITY PRIMARY KEY,
    ID_cliente INT,
    data_reserva DATETIME,
    num_pessoas INT,
    mesa VARCHAR(10),
    FOREIGN KEY (ID_cliente) REFERENCES tb_clientes(UserId)
);
GO

CREATE TABLE tb_status_pedido (
    status_id INT PRIMARY KEY,
    status_nome VARCHAR(50)
);
GO

CREATE TABLE tb_tipo_pedido (
    tipo_id INT IDENTITY PRIMARY KEY,
    tipo_nome VARCHAR(50)
);
GO

CREATE TABLE tb_pedidos (
    ID_pedido VARCHAR(10) PRIMARY KEY,
    data_pedido DATETIME,
    hora_entrega DATETIME NULL,
    codigo_localizador VARCHAR(50) NULL,
    ID_cliente INT,
    status_id INT,
    tipo_id INT,
    modo_consumo VARCHAR(20),
    endereco_completo VARCHAR(255),
    nome_entregador VARCHAR(100) NULL,
    telefone_entregador VARCHAR(20) NULL,
    observacoes VARCHAR(255) NULL,
    ID_reserva INT NULL,
    FOREIGN KEY (ID_cliente) REFERENCES tb_clientes(UserId),
    FOREIGN KEY (status_id) REFERENCES tb_status_pedido(status_id),
    FOREIGN KEY (tipo_id) REFERENCES tb_tipo_pedido(tipo_id),
    FOREIGN KEY (ID_reserva) REFERENCES tb_reservas(ID_reserva)
);
GO

CREATE TABLE tb_pedidos_produtos (
    ID_pedido VARCHAR(10),
    ID_produto INT,
    quantidade INT,
    PRIMARY KEY (ID_pedido, ID_produto),
    FOREIGN KEY (ID_pedido) REFERENCES tb_pedidos(ID_pedido),
    FOREIGN KEY (ID_produto) REFERENCES tb_produtos(ID_produto)
);
GO

CREATE TABLE tb_cupons (
    ID_cupom INT IDENTITY PRIMARY KEY,
    codigo_cupom VARCHAR(50),
    desconto DECIMAL(5,2),
    validade DATE
);
GO

CREATE TABLE tb_avaliacoes (
    ID_avaliacao INT IDENTITY PRIMARY KEY,
    ID_cliente INT,
    ID_produto INT,
    comentario VARCHAR(255),
    nota INT,
    data_avaliacao DATE,
    FOREIGN KEY (ID_cliente) REFERENCES tb_clientes(UserId),
    FOREIGN KEY (ID_produto) REFERENCES tb_produtos(ID_produto)
);
GO

CREATE TABLE tb_pagamentos (
    ID_pagamento INT IDENTITY PRIMARY KEY,
    ID_pedido VARCHAR(10),
    metodo_pagamento VARCHAR(50),
    valor_total DECIMAL(10,2),
    data_pagamento DATE,
    FOREIGN KEY (ID_pedido) REFERENCES tb_pedidos(ID_pedido)
);
GO

CREATE TABLE tb_fidelidade (
    ID_fidelidade INT IDENTITY PRIMARY KEY,
    ID_cliente INT,
    pontos INT,
    cashback DECIMAL(10,2),
    FOREIGN KEY (ID_cliente) REFERENCES tb_clientes(UserId)
);
GO

CREATE TABLE tb_funcionarios (
    userID INT IDENTITY PRIMARY KEY,
    name VARCHAR(100),
    userName VARCHAR(50),
    email VARCHAR(100),
    role VARCHAR(50),
    phone VARCHAR(20),
    password VARCHAR(255),
    registrationDate VARCHAR(20),
    status VARCHAR(20)
);
GO

