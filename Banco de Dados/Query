CREATE DATABASE FoodVerseDB;

USE FoodVerseDB;


-- Tabela: tb_clientes
CREATE TABLE tb_clientes (
    UserId INT IDENTITY PRIMARY KEY,
    user_name VARCHAR(100),
    name VARCHAR(100),
    email VARCHAR(100),
    phone VARCHAR(100),
    password VARCHAR(255),
    cpf VARCHAR(255),
    registrationDate DATE,
    isLogin BIT
);

-- Tabela: tb_produtos
CREATE TABLE tb_produtos (
    ID_produto INT IDENTITY PRIMARY KEY,
    nome_produto VARCHAR(100),
    des_produto VARCHAR(255),
    preco_produto DECIMAL(10,2)
);

-- Tabela: tb_reservas (com coluna mesa)
CREATE TABLE tb_reservas (
    ID_reserva INT IDENTITY PRIMARY KEY,
    ID_cliente INT,
    data_reserva DATETIME,
    num_pessoas INT,
    mesa VARCHAR(10), -- adicionada a coluna de mesa
    FOREIGN KEY (ID_cliente) REFERENCES tb_clientes(UserId)
);

-- Tabela: tb_pedidos (com FK para reservas)
CREATE TABLE tb_pedidos (
    ID_pedido INT IDENTITY PRIMARY KEY,
    data_pedido DATETIME,
    ID_cliente INT,
    status_pedido VARCHAR(50),
    tipo_pedido VARCHAR(50),
    ID_reserva INT NULL,
    FOREIGN KEY (ID_cliente) REFERENCES tb_clientes(UserId),
    FOREIGN KEY (ID_reserva) REFERENCES tb_reservas(ID_reserva)
);

-- Tabela: tb_pedidos_produtos (associativa)
CREATE TABLE tb_pedidos_produtos (
    ID_pedido INT,
    ID_produto INT,
    quantidade INT,
    PRIMARY KEY (ID_pedido, ID_produto),
    FOREIGN KEY (ID_pedido) REFERENCES tb_pedidos(ID_pedido),
    FOREIGN KEY (ID_produto) REFERENCES tb_produtos(ID_produto)
);

-- Tabela: tb_cupons
CREATE TABLE tb_cupons (
    ID_cupom INT IDENTITY PRIMARY KEY,
    codigo_cupom VARCHAR(50),
    desconto DECIMAL(5,2),
    validade DATE
);

-- Tabela: tb_avaliacoes
CREATE TABLE tb_avaliacoes (
    ID_avaliacao INT IDENTITY PRIMARY KEY,
    ID_cliente INT,
    ID_produto INT,
    comentario VARCHAR(255),
    nota INT,
    data_avaliacao DATE,
    FOREIGN KEY (ID_cliente) REFERENCES tb_clientes(UserId),
    FOREIGN KEY (ID_produto) REFERENCES tb_produtos(ID_produto)
);

-- Tabela: tb_pagamentos
CREATE TABLE tb_pagamentos (
    ID_pagamento INT IDENTITY PRIMARY KEY,
    ID_pedido INT,
    metodo_pagamento VARCHAR(50),
    valor_total DECIMAL(10,2),
    data_pagamento DATE,
    FOREIGN KEY (ID_pedido) REFERENCES tb_pedidos(ID_pedido)
);

-- Tabela: tb_fidelidade
CREATE TABLE tb_fidelidade (
    ID_fidelidade INT IDENTITY PRIMARY KEY,
    ID_cliente INT,
    pontos INT,
    cashback DECIMAL(10,2),
    FOREIGN KEY (ID_cliente) REFERENCES tb_clientes(UserId)
);

-- Tabela: tb_funcionarios
CREATE TABLE tb_funcionarios (
    userID INT IDENTITY PRIMARY KEY,
    name VARCHAR(100),
    userName VARCHAR(50),
    email VARCHAR(100),
    role VARCHAR(50),
    phone VARCHAR(20),
    password VARCHAR(255),
    registrationDate VARCHAR(20),
    status VARCHAR(20)
);

