@startuml DiagramaCasoDeUso_FoodVerse

' ==========================================================
' CONFIGURAÇÃO — A4 Paisagem (297 x 210 mm)
' ==========================================================
left to right direction
scale max 1122 width
scale max 793 height

skinparam actorStyle awesome
skinparam packageStyle rectangle
skinparam backgroundColor #FFFFFF
skinparam ArrowColor #444444
skinparam ActorBorderColor #1A5276
skinparam ActorBackgroundColor #D6EAF8
skinparam ActorFontSize 9
skinparam UsecaseBorderColor #1A5276
skinparam UsecaseBackgroundColor #EBF5FB
skinparam UsecaseFontSize 9
skinparam defaultFontName Arial
skinparam defaultFontSize 9
skinparam nodesep 6
skinparam ranksep 18
skinparam padding 2

title FoodVerse — Diagrama de Caso de Uso

' ========================
' ATORES — esquerda
' ========================
actor "Cliente" as cliente

' ========================
' PORTAL WEB (Django) — centro-esquerda
' ========================
rectangle "Portal Web (Django)" #EBF5FB {

  package "Conta e Perfil" {
    usecase "Criar conta" as UC_Cadastro
    usecase "Fazer login" as UC_LoginCliente
    usecase "Fazer logout" as UC_LogoutCliente
    usecase "Ver perfil" as UC_VerPerfil
    usecase "Editar perfil" as UC_EditarPerfil
  }

  package "Pedidos e Carrinho" {
    usecase "Buscar restaurantes" as UC_Buscar
    usecase "Ver cardápio" as UC_VerCardapio
    usecase "Ver detalhes do prato" as UC_VerPrato
    usecase "Adicionar ao carrinho" as UC_Carrinho
    usecase "Alterar quantidade" as UC_AltQtd
    usecase "Finalizar pedido" as UC_Finalizar
    usecase "Aplicar cupom" as UC_Cupom
    usecase "Histórico de pedidos" as UC_Historico
  }

  package "Reservas e Avaliações" {
    usecase "Reservar mesa" as UC_Reserva
    usecase "Pagar reserva" as UC_PagarReserva
    usecase "Avaliar restaurante" as UC_Avaliacao
  }

}

' ========================
' DESKTOP (Java) — centro-direita
' ========================
rectangle "App Desktop (Java/Swing)" #FEF9E7 {

  package "Acesso" {
    usecase "Fazer login" as UC_LoginFunc
    usecase "Dashboard / Home" as UC_Dashboard
  }

  package "Gestão Administrativa" {
    usecase "Aprovar cadastro\nde funcionário" as UC_Aprovacao
    usecase "Gerenciar restaurantes" as UC_GerRest
    usecase "Configurar restaurante" as UC_ConfigRest
  }

  package "Operações do Restaurante" {
    usecase "Gerenciar cardápio" as UC_Cardapio
    usecase "Receita de prato (BOM)" as UC_Receita
    usecase "Gerenciar estoque" as UC_Estoque
    usecase "Criar pedido local\n(mesa / balcão)" as UC_PedidoLocal
    usecase "Gerenciar pedidos" as UC_Pedidos
    usecase "Painel de cozinha (KDS)" as UC_Cozinha
    usecase "Gerenciar entregas" as UC_Entregas
    usecase "Mesas e reservas" as UC_Mesas
  }

}

' ========================
' ATORES — direita
' ========================
actor "Funcionário" as funcionario
actor "Admin" as admin
actor "Gerente" as gerente
actor "Atendente" as atendente
actor "Cozinheiro" as cozinheiro
actor "Entregador" as entregador

admin      --|> funcionario
gerente    --|> funcionario
atendente  --|> funcionario
cozinheiro --|> funcionario
entregador --|> funcionario

' ========================
' ASSOCIAÇÕES — CLIENTE
' ========================
cliente --> UC_Cadastro
cliente --> UC_LoginCliente
cliente --> UC_LogoutCliente
cliente --> UC_VerPerfil
cliente --> UC_EditarPerfil
cliente --> UC_Buscar
cliente --> UC_VerCardapio
cliente --> UC_VerPrato
cliente --> UC_Carrinho
cliente --> UC_AltQtd
cliente --> UC_Finalizar
cliente --> UC_Historico
cliente --> UC_Reserva
cliente --> UC_Avaliacao

UC_Finalizar .> UC_Cupom : <<include>>
UC_Reserva   .> UC_PagarReserva : <<include>>

' ========================
' ASSOCIAÇÕES — FUNCIONÁRIO
' ========================
funcionario --> UC_LoginFunc
funcionario --> UC_Dashboard

admin --> UC_Aprovacao
admin --> UC_GerRest

gerente --> UC_Aprovacao
gerente --> UC_ConfigRest
gerente --> UC_Cardapio
gerente --> UC_Receita
gerente --> UC_Estoque
gerente --> UC_Pedidos
gerente --> UC_Entregas
gerente --> UC_Mesas

atendente --> UC_Pedidos
atendente --> UC_PedidoLocal
atendente --> UC_Mesas

cozinheiro --> UC_Cozinha
cozinheiro --> UC_Pedidos

entregador --> UC_Entregas

' ========================
' EXTENSÕES
' ========================
UC_Receita    .> UC_Cardapio  : <<extend>>
UC_PedidoLocal .> UC_Pedidos  : <<extend>>

@enduml
